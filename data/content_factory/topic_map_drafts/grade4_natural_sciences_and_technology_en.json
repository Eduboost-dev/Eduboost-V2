          "topic_index": 2,
          "topic": "The Sun",
          "time": "1 week (3.5 hours)",
          "subtopics": [
            {
              "caps_ref": "4.NST.4.2.1",
              "subtopic_index": 1,
              "subtopic": "The Sun as our closest star",
              "assessment_standards": [
                "Describe the Sun as a star made of hot gas.",
                "Explain that the Sun gives out heat and light.",
                "Explain that the Sun is much bigger than Earth, very far away, and the closest star to Earth.",
                "Explain that the Sun provides heat and light for living things on Earth."
              ],
              "prerequisites": [
                "4.NST.4.1.2"
              ],
              "common_misconceptions": [
