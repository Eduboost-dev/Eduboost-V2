          "caps_ref": "4.NST.4.5",
          "topic_index": 5,
          "topic": "Rocket systems",
          "time": "2 weeks (7 hours)",
          "subtopics": [
            {
              "caps_ref": "4.NST.4.5.1",
              "subtopic_index": 1,
              "subtopic": "Modelling a rocket",
              "assessment_standards": [
