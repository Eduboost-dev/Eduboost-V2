              ],
              "prerequisites": [
                "4.NST.4.4.1"
              ],
              "common_misconceptions": [
                "cultural_stories_treated_as_scientific_measurements",
                "science_learning_seen_as_excluding_culture"
              ]
            }
          ]
        },
