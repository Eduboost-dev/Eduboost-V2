          "topic_index": 3,
          "topic": "The Earth and the Sun",
          "time": "1 week (3.5 hours)",
          "subtopics": [
            {
              "caps_ref": "4.NST.4.3.1",
              "subtopic_index": 1,
              "subtopic": "Earth orbit and the solar system",
              "assessment_standards": [
                "Explain that Earth moves around the Sun in an orbit.",
                "Recognise the Sun as a star at the centre of the solar system.",
                "Recognise Earth as one of eight planets in the solar system.",
                "Explain that Earth receives enough light and heat from the Sun to support life."
              ],
              "prerequisites": [
                "4.NST.4.2.1"
