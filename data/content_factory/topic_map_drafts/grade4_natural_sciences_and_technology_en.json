              "subtopic_index": 2,
              "subtopic": "Earth and space",
              "assessment_standards": [
                "Explain that Earth is a planet in space.",
                "Identify the Sun, Moon and stars as objects visible from Earth."
              ],
              "prerequisites": [
                "4.NST.4.1.1"
              ],
              "common_misconceptions": [
                "sun_and_moon_seen_as_same_type_of_object",
