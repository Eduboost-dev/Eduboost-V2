          "topic": "The Moon",
          "time": "2 weeks (7 hours)",
          "subtopics": [
            {
              "caps_ref": "4.NST.4.4.1",
              "subtopic_index": 1,
              "subtopic": "Features and phases of the Moon",
              "assessment_standards": [
                "Describe the Moon as a ball of rock in space with no air or water.",
                "Compare the Moon with Earth and the Sun by size and distance.",
                "Explain that phases of the Moon result from the changing pattern of sunlight visible on the Moon.",
                "Observe and record Moon phases over about a month."
              ],
              "prerequisites": [
                "4.NST.4.1.2"
