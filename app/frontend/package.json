{
  "name": "eduboost-sa-frontend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3050",
    "build": "next build --webpack",
    "start": "next start -p ${PORT:-3050} -H 0.0.0.0",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --cache --cache-location .eslintcache",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "env-check": "python3 ../../scripts/validate_frontend_env.py",
    "a11y-check": "vitest run src/__tests__/AccessibilityContracts.test.tsx",
    "analyze": "ANALYZE=true pnpm run build",
    "pr-007-check": "pnpm run env-check && pnpm run type-check && pnpm run test",
    "ci:lighthouse": "npx -y lighthouse@10 --output html --output json --output-path=./tmp/lh-staging --chrome-flags=\"--headless\" \"$STAGING_URL\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@serwist/next": "^9.5.11",
    "@supabase/auth-helpers-nextjs": "0.15.0",
    "@supabase/supabase-js": "^2.105.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.4.0",
    "dexie": "^4.4.3",
    "framer-motion": "11.2.6",
    "lucide-react": "^1.16.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.76.1",
    "recharts": "2.12.7",
    "serwist": "^9.5.11",
    "sonner": "^2.0.7",
    "swr": "2.2.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "8.20.1",
    "zod": "^4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.5.18",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@types/node": "20.12.7",
    "@types/react": "18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "10.5.0",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.18",
    "jsdom": "^29.1.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5",
    "vitest": "4.1.7"
  }
}
